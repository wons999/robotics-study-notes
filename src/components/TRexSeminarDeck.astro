    display: grid;
    grid-template-columns: 2.75rem minmax(4rem, 1fr) 2.75rem auto;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem;
    border-bottom: 1px solid var(--sl-color-gray-5);
    background: var(--sl-color-bg-nav);
  }

  .image-lightbox[hidden] {
    display: none;
  }

  .image-lightbox {
    position: fixed;
    inset: 0;
    z-index: 10000;
    display: grid;
    place-items: center;
    padding: clamp(1rem, 2vw, 2rem);
  }

  .lightbox-backdrop {
    position: absolute;
    inset: 0;
    border: 0;
    background: color-mix(in srgb, var(--sl-color-black) 84%, transparent);
    cursor: zoom-out;
  }

  .lightbox-panel {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-rows: minmax(0, 1fr) auto;
    gap: 0.6rem;
    width: min(96vw, 1600px);
    height: min(92vh, 960px);
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 8px;
    background: var(--sl-color-bg);
    padding: 0.8rem;
    box-shadow: 0 24px 70px color-mix(in srgb, var(--sl-color-black) 60%, transparent);
  }

  .lightbox-panel img {
    width: 100%;
    height: 100%;
    min-height: 0;
    object-fit: contain;
    background: white;
    border-radius: 6px;
  }

  .lightbox-panel p {
    margin: 0;
    color: var(--sl-color-gray-2);
    font-size: 0.9rem;
    text-align: center;
  }

  .lightbox-close {
    position: absolute;
    top: 0.6rem;
    right: 0.6rem;
    z-index: 2;
    width: 2.25rem;
    height: 2.25rem;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 999px;
    background: var(--sl-color-bg-nav);
    color: var(--sl-color-white);
    cursor: pointer;
    font-size: 1.3rem;
    line-height: 1;
  }

  .icon-button,
  .deck-button {
    height: 2.25rem;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 8px;
    background: var(--sl-color-bg);
    color: var(--sl-color-white);
    cursor: pointer;
  }

  .icon-button {
    width: 2.25rem;
    font-size: 1.6rem;
    line-height: 1;
  }

  .deck-button {
    padding: 0 0.85rem;
    font-size: 0.85rem;
  }

  .icon-button:disabled {
    opacity: 0.35;
    cursor: default;
  }

  .slide-status {
    justify-self: center;
    display: inline-flex;
    gap: 0.25rem;
    font-variant-numeric: tabular-nums;
    color: var(--sl-color-gray-2);
  }

  .progress-track {
    height: 0.3rem;
