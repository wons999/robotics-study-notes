---
const assetBase = import.meta.env.BASE_URL.replace(/\/$/, '');
const trexAssetPrefix = `${assetBase}/trex/`;
const withPublicAssetBase = (html: string) => html.replaceAll('src="/trex/', `src="${trexAssetPrefix}`);
const toSlidePoint = (text: string) => {
  const normalized = text.replace(/\s+/g, ' ').trim();
  if (normalized.length <= 140) return normalized;
  const firstSentence = normalized.match(/^.*?(?:(?<=[가-힣])\.|[!?]|[A-Za-z)\]]\.(?=\s|$))/u)?.[0];
  if (firstSentence && firstSentence.length >= 40 && firstSentence.length <= 180) {
    return firstSentence.trim();
  }
  const commaPoint = normalized.split(/[,，]/).slice(0, 2).join(',').trim();
  if (commaPoint.length >= 40 && commaPoint.length <= 150) return `${commaPoint}.`;
  return normalized;
};

